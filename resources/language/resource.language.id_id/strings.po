msgctxt "#32203"
msgid "Shows each log line as a visual item.\nColor-coded by severity:\n\n[COLOR red]X Error[/COLOR]\n[COLOR yellow]! Warning[/COLOR]\n[COLOR white]- Info[/COLOR]\n[COLOR grey]- Debug[/COLOR]"
msgstr "Menampilkan setiap baris log sebagai item visual.\nKode warna berdasarkan tingkat keparahan:\n\n[COLOR red]X Kesalahan[/COLOR]\n[COLOR yellow]! Peringatan[/COLOR]\n[COLOR white]- Info[/COLOR]\n[COLOR grey]- Debug[/COLOR]"

msgctxt "#32204"
