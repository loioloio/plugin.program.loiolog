# --- Menu plots ---
msgctxt "#32200"
msgid "Shows recent Kodi log entries"
msgstr "हालिया कोडी लॉग प्रविष्टियां दिखाता है"

msgctxt "#32201"
msgid " mentioning {0}."
msgstr " {0} का उल्लेख करते हुए।"

msgctxt "#32202"
msgid "Sensitive tokens and data are automatically redacted."
msgstr "संवेदनशील टोकन और डेटा स्वचालित रूप से छुपा दिए जाते हैं।"

msgctxt "#32203"
msgid "Shows each log line as a visual item.\nColor-coded by severity:\n\n[COLOR red]X Error[/COLOR]\n[COLOR yellow]! Warning[/COLOR]\n[COLOR white]- Info[/COLOR]\n[COLOR grey]- Debug[/COLOR]"
msgstr "प्रत्येक लॉग लाइन को एक दृश्य आइटम के रूप में दिखाता है।\nगंभीरता के आधार पर रंग-कोडित:\n\n[COLOR red]X त्रुटि[/COLOR]\n[COLOR yellow]! चेतावनी[/COLOR]\n[COLOR white]- जानकारी[/COLOR]\n[COLOR grey]- डिबग[/COLOR]"

msgctxt "#32204"
msgid "Shows the complete Kodi log."
msgstr "पूरा कोडी लॉग दिखाता है।"

msgctxt "#32205"
msgid "Filters the log for error, warning, exception and traceback lines."
msgstr "लॉग को त्रुटि, चेतावनी, अपवाद और ट्रेसबैक लाइनों के लिए फ़िल्टर करता है।"

msgctxt "#32206"
msgid "Shows the internal addon log contents."
msgstr "आंतरिक एडऑन लॉग सामग्री दिखाता है।"

msgctxt "#32207"
msgid "Type a text to search the full Kodi log.\nShows all matching lines."
msgstr "पूरे कोडी लॉग में खोजने के लिए टेक्स्ट टाइप करें।\nसभी मेल खाने वाली पंक्तियाँ दिखाता है।"

msgctxt "#32208"
msgid "Save the filtered, complete or error-only log to a TXT file.\nUseful for sharing or sending to support."
msgstr "फ़िल्टर किए गए, पूर्ण या केवल-त्रुटि लॉग को TXT फ़ाइल में सहेजें।\nसाझा करने या समर्थन को भेजने के लिए उपयोगी।"

msgctxt "#32209"
msgid "Shows file size, line count and path of the Kodi log."
msgstr "कोडी लॉग का फ़ाइल आकार, लाइन संख्या और पथ दिखाता है।"

msgctxt "#32210"
msgid "Deletes the internal addon log file."
msgstr "आंतरिक एडऑन लॉग फ़ाइल हटाता है।"

msgctxt "#32211"
msgid "View the old Kodi log (kodi.old.log) from the previous session."
msgstr "पिछले सत्र का पुराना कोडी लॉग (kodi.old.log) देखें।"

msgctxt "#32212"
msgid "Enable or disable Kodi debug logging."
msgstr "कोडी डिबग लॉगिंग सक्षम या अक्षम करें।"

msgctxt "#32213"
msgid "Error, warning and addon mention counts."
msgstr "त्रुटि, चेतावनी और एडऑन उल्लेख संख्या।"

msgctxt "#32214"
msgid "Compare errors between current and old log."
msgstr "वर्तमान और पुराने लॉग के बीच त्रुटियों की तुलना करें।"

msgctxt "#32215"
msgid "Kodi version, platform, screen resolution and Python version."
msgstr "कोडी संस्करण, प्लेटफ़ॉर्म, स्क्रीन रिज़ॉल्यूशन और पायथन संस्करण।"

msgctxt "#32216"
msgid "Copy the kodi.log file path to clipboard."
msgstr "kodi.log फ़ाइल पथ को क्लिपबोर्ड पर कॉपी करें।"

msgctxt "#32217"
msgid "Select an installed addon and immediately view its log entries."
msgstr "एक स्थापित एडऑन चुनें और तुरंत इसके लॉग प्रविष्टियां देखें।"

msgctxt "#32218"
msgid "Delete kodi.log and/or kodi.old.log files."
msgstr "kodi.log और/या kodi.old.log फ़ाइलें हटाएं।"

