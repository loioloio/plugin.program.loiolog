msgid "Tools"
msgstr "उपकरण"

msgctxt "#32305"
msgid "Danger zone"
msgstr "ख़तरे का क्षेत्र"

# --- Network log viewer ---
msgctxt "#32310"
msgid "View log on network"
msgstr "नेटवर्क पर लॉग देखें"

msgctxt "#32311"
msgid "Open this URL on your phone or any device on the same network:\n\n{0}\n\nThe URL has been copied to clipboard.\nClose this dialog to stop the server."
msgstr "अपने फोन या उसी network पर किसी भी डिवाइस पर यह URL खोलें:\n\n{0}\n\nURL क्लिपबोर्ड पर कॉपी कर लिया गया है।\nसर्वर को रोकने के लिए इस संवाद को बंद करें।"

msgctxt "#32312"
msgid "Start a local web server to view the Kodi log from your phone or another device on the same network."
msgstr "अपने फोन या उसी नेटवर्क पर किसी अन्य डिवाइस से कोडी लॉग देखने के लिए एक स्थानीय वेब सर्वर शुरू करें।"

msgctxt "#32313"
msgid "Port {0} is already in use. Try again later."
msgstr "पोर्ट {0} पहले से उपयोग में है। बाद में पुन: प्रयास करें।"

# --- Reverse order toggle ---
msgctxt "#32314"
msgid "Order: oldest first"
msgstr "क्रम: पुराना पहले"

msgctxt "#32315"
msgid "Order: newest first"
msgstr "क्रम: नया पहले"

msgctxt "#32316"
msgid "Toggle between showing newest or oldest log entries first."
msgstr "सबसे पुरानी या सबसे नई लॉग प्रविष्टियों को पहले दिखाने के बीच स्विच करें।"

# --- Known issues in stats ---
msgctxt "#32320"
msgid "Known issues detected"
msgstr "ज्ञात समस्याएं पाई गईं"

msgctxt "#32321"
msgid "Database locked: {0:,}"
msgstr "डेटाबेस लॉक: {0:,}"

msgctxt "#32322"
msgid "Connection timeouts: {0:,}"
msgstr "कनेक्शन टाइमआउट: {0:,}"

msgctxt "#32323"
msgid "Missing dependencies: {0:,}"
msgstr "अनुपलब्ध निर्भरताएँ: {0:,}"

msgctxt "#32324"
msgid "Playback failures: {0:,}"
msgstr "प्लेबैक विफलता: {0:,}"

# --- QR code sharing ---
msgctxt "#32325"
msgid "Show QR code"
msgstr "क्यूआर कोड दिखाएं"

msgctxt "#32326"
msgid "Scan with your phone to open the log"
msgstr "लॉग खोलने के लिए अपने फोन से स्कैन करें"

msgctxt "#32327"
msgid "Press Back to close"
msgstr "बंद करने के लिए बैक दबाएं"

msgctxt "#32328"
msgid "Could not generate the QR code: {0}"
msgstr "क्यूआर कोड उत्पन्न नहीं किया जा सका: {0}"

msgctxt "#32329"
msgid "Close"
msgstr "बंद करें"
