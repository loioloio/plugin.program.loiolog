msgctxt "#32203"
msgid "Shows each log line as a visual item.\nColor-coded by severity:\n\n[COLOR red]X Error[/COLOR]\n[COLOR yellow]! Warning[/COLOR]\n[COLOR white]- Info[/COLOR]\n[COLOR grey]- Debug[/COLOR]"
msgstr "ہر لاگ سطر کو ایک بصری آئٹم کے طور پر دکھاتا ہے۔\nشدت کے لحاظ سے رنگین کوڈ شدہ:\n\n[COLOR red]X غلطی[/COLOR]\n[COLOR yellow]! انتباہ[/COLOR]\n[COLOR white]- معلومات[/COLOR]\n[COLOR grey]- ڈیبگ[/COLOR]"

msgctxt "#32204"
msgid "Shows the complete Kodi log."
msgstr "مکمل کوڈی لاگ دکھاتا ہے۔"

