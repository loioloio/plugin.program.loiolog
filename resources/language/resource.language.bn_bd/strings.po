# --- Network log viewer ---
msgctxt "#32310"
msgid "View log on network"
msgstr "নেটওয়ার্কে লগ দেখুন"

msgctxt "#32311"
msgid "Open this URL on your phone or any device on the same network:\n\n{0}\n\nThe URL has been copied to clipboard.\nClose this dialog to stop the server."
msgstr "আপনার ফোন বা একই নেটওয়ার্কের যেকোনো ডিভাইসে এই URLটি খুলুন:\n\n{0}\n\nURL ক্লিপবোর্ডে কপি করা হয়েছে।\nসার্ভার বন্ধ করতে এই ডায়ালগটি বন্ধ করুন।"

msgctxt "#32312"
msgid "Start a local web server to view the Kodi log from your phone or another device on the same network."
msgstr "আপনার ফোন বা একই নেটওয়ার্কের অন্য কোনো ডিভাইস থেকে কোডি লগ দেখতে একটি স্থানীয় ওয়েব সার্ভার শুরু করুন।"

msgctxt "#32313"
msgid "Port {0} is already in use. Try again later."
msgstr "পোর্ট {0} ইতিমধ্যে ব্যবহার করা হচ্ছে। পরে আবার চেষ্টা করুন।"

# --- Reverse order toggle ---
msgctxt "#32314"
msgid "Order: oldest first"
msgstr "ক্রম: প্রাচীনতম আগে"

msgctxt "#32315"
msgid "Order: newest first"
msgstr "ক্রম: নতুন আগে"

msgctxt "#32316"
msgid "Toggle between showing newest or oldest log entries first."
msgstr "সবচেয়ে নতুন নাকি প্রাচীনতম লগ এন্ট্রি আগে দেখানো হবে তা টগল করুন।"

