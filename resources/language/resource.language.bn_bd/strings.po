msgstr "লগ আপলোড করা হচ্ছে..."

msgctxt "#32272"
msgid "Log uploaded successfully!\n\nURL:\n{0}\n\nThe URL has been copied to clipboard."
msgstr "লগ সফলভাবে আপলোড করা হয়েছে!\n\nURL:\n{0}\n\nURL ক্লিপবোর্ডে কপি করা হয়েছে।"

