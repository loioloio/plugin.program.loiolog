msgid "Shows recent Kodi log entries"
msgstr "সাম্প্রতিক কোডি লগ এন্ট্রি দেখায়"

msgctxt "#32201"
msgid " mentioning {0}."
msgstr " {0} উল্লেখ করে।"

msgctxt "#32202"
msgid "Sensitive tokens and data are automatically redacted."
msgstr "সংবেদনশীল টোকেন এবং ডেটা স্বয়ংক্রিয়ভাবে মুছে ফেলা হয়।"

msgctxt "#32203"
msgid "Shows each log line as a visual item.\nColor-coded by severity:\n\n[COLOR red]X Error[/COLOR]\n[COLOR yellow]! Warning[/COLOR]\n[COLOR white]- Info[/COLOR]\n[COLOR grey]- Debug[/COLOR]"
msgstr "প্রতিটি লগ লাইন একটি ভিজ্যুয়াল আইটেম হিসাবে দেখায়।\nতীব্রতা অনুসারে রঙিন কোডেড:\n\n[COLOR red]X ত্রুটি[/COLOR]\n[COLOR yellow]! সতর্কতা[/COLOR]\n[COLOR white]- তথ্য[/COLOR]\n[COLOR grey]- ডিবাগ[/COLOR]"

msgctxt "#32204"
msgid "Shows the complete Kodi log."
msgstr "সম্পূর্ণ কোডি লগ দেখায়।"

msgctxt "#32205"
msgid "Filters the log for error, warning, exception and traceback lines."
msgstr "ত্রুটি, সতর্কতা, ব্যতিক্রম এবং ট্রেসব্যাক লাইনের জন্য লগ ফিল্টার করে।"

msgctxt "#32206"
msgid "Shows the internal addon log contents."
msgstr "অভ্যন্তরীণ অ্যাডঅন লগের বিষয়বস্তু দেখায়।"

msgctxt "#32207"
msgid "Type a text to search the full Kodi log.\nShows all matching lines."
msgstr "সম্পূর্ণ কোডি লগে অনুসন্ধান করতে পাঠ্য লিখুন।\nসব মিলতি লাইন দেখায়।"

msgctxt "#32208"
msgid "Save the filtered, complete or error-only log to a TXT file.\nUseful for sharing or sending to support."
msgstr "ফিল্টার করা, সম্পূর্ণ বা ত্রুটি-অনন্য লগ একটি TXT ফাইলে সংরক্ষণ করুন।\nশেয়ার করার জন্য বা সমর্থনে পাঠানোর জন্য দরকারী।"

msgctxt "#32209"
msgid "Shows file size, line count and path of the Kodi log."
msgstr "কোডি লগের ফাইলের আকার, লাইন সংখ্যা এবং পাথ দেখায়।"

msgctxt "#32210"
msgid "Deletes the internal addon log file."
msgstr "অভ্যন্তরীণ অ্যাডঅন লগ ফাইল মুছে দেয়।"

msgctxt "#32211"
msgid "View the old Kodi log (kodi.old.log) from the previous session."
msgstr "পূর্ববর্তী সেশনের পুরানো কোডি লগ (kodi.old.log) দেখুন।"

msgctxt "#32212"
msgid "Enable or disable Kodi debug logging."
msgstr "কোডি ডিবাগ লগিং সক্ষম বা নিষ্ক্রিয় করুন।"

msgctxt "#32213"
msgid "Error, warning and addon mention counts."
msgstr "ত্রুটি, সতর্কতা এবং অ্যাডঅন উল্লেখের संख्या।"

msgctxt "#32214"
msgid "Compare errors between current and old log."
msgstr "বর্তমান এবং পুরানো লগের মধ্যে ত্রুটি তুলনা করুন।"

msgctxt "#32215"
msgid "Kodi version, platform, screen resolution and Python version."
msgstr "কোডি সংস্করণ, প্ল্যাটফর্ম, স্ক্রিন রেজোলিউশন এবং পাইথন সংস্করণ।"

msgctxt "#32216"
msgid "Copy the kodi.log file path to clipboard."
msgstr "kodi.log ফাইল পাথ ক্লিপবোর্ডে কপি করুন।"

msgctxt "#32217"
msgid "Select an installed addon and immediately view its log entries."
msgstr "একটি ইনস্টল করা অ্যাডঅন নির্বাচন করুন এবং অবিলম্বে এর লগ এন্ট্রি দেখুন।"

msgctxt "#32218"
msgid "Delete kodi.log and/or kodi.old.log files."
msgstr "kodi.log এবং/অথবা kodi.old.log ফাইল মুছুন।"

