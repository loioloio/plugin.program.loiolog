msgid "Sensitive tokens and data are automatically redacted."
msgstr "Các token và dữ liệu nhạy cảm tự động bị ẩn."

msgctxt "#32203"
msgid "Shows each log line as a visual item.\nColor-coded by severity:\n\n[COLOR red]X Error[/COLOR]\n[COLOR yellow]! Warning[/COLOR]\n[COLOR white]- Info[/COLOR]\n[COLOR grey]- Debug[/COLOR]"
msgstr "Hiển thị mỗi dòng log như một mục trực quan.\nMã màu theo mức độ nghiêm trọng:\n\n[COLOR red]X Lỗi[/COLOR]\n[COLOR yellow]! Cảnh báo[/COLOR]\n[COLOR white]- Thông tin[/COLOR]\n[COLOR grey]- Debug[/COLOR]"

msgctxt "#32204"
msgid "Shows the complete Kodi log."
