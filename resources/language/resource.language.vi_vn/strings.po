msgctxt "#32210"
msgid "Deletes the internal addon log file."
msgstr "Xóa file log addon nội bộ."

msgctxt "#32211"
msgid "View the old Kodi log (kodi.old.log) from the previous session."
msgstr "Xem log Kodi cũ (kodi.old.log) từ phiên làm việc trước."

