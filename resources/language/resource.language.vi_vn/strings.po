msgctxt "#32205"
msgid "Filters the log for error, warning, exception and traceback lines."
msgstr "Lọc log cho các dòng lỗi, cảnh báo, ngoại lệ và traceback."

msgctxt "#32206"
msgid "Shows the internal addon log contents."
msgstr "Hiển thị nội dung log addon nội bộ."

msgctxt "#32207"
